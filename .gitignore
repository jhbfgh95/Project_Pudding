# Unreal Engine generated files
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Plugins/**/Binaries/
Plugins/**/Intermediate/

# Build outputs; retain build configuration and application icons.
Build/*
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt
!Build/**/*.ico

# IDE and local workspace files
.vs/
.vscode/
*.sln
*.VC.db
*.VC.opendb
*.opensdf
*.sdf
*.suo
*.xcodeproj
*.xcworkspace
*.vsconfig

# Compiled native artifacts
*.obj
*.o
*.pch
*.dll
*.lib
*.exe

# Local logs and temporary files
*.log
*.tmp

# Keep Unreal project content, including LFS-tracked assets, in version control.
!Content/
!Config/
